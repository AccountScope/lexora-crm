# ───────────────────────────
# Shared
# ───────────────────────────
NODE_ENV=production
DEPLOYMENT_MODE=supabase        # supabase | self_hosted
NEXT_PUBLIC_APP_URL=https://app.lexora.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key

# ───────────────────────────
# Fast Path (Supabase + Vercel)
# ───────────────────────────
SUPABASE_SERVICE_ROLE_KEY=service-role-key
SUPABASE_JWT_SECRET=supabase-jwt-secret
SUPABASE_DB_URL=postgresql://db-user:db-password@db.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=case-files

# ───────────────────────────
# Air-Gapped / Self-Hosted
# ───────────────────────────
SELF_HOSTED_APP_URL=https://lexora.local
SELF_HOSTED_API_URL=https://lexora.local/api

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lexora
DB_USER=lexora
DB_PASSWORD=change-me
DB_SSL=false

# Auth (Custom JWT)
AUTH_ISSUER=https://lexora.local/auth
AUTH_AUDIENCE=lexora-enterprise
AUTH_JWT_ALGO=HS256
AUTH_JWT_SIGNING_KEY=change-me
AUTH_JWT_PUBLIC_KEY=optional-public-key

# Storage (MinIO)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=case-files
MINIO_ROOT_USER=lexora
MINIO_ROOT_PASSWORD=change-me
MINIO_REGION=us-east-1

# ───────────────────────────
# Optional
# ───────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
