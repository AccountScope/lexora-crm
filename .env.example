# ───────────────────────────
# Shared
# ───────────────────────────
NODE_ENV=production
DEPLOYMENT_MODE=supabase        # supabase | self_hosted
NEXT_PUBLIC_APP_URL=https://app.lexora.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key

# ───────────────────────────
# Fast Path (Supabase + Vercel)
# ───────────────────────────
SUPABASE_SERVICE_ROLE_KEY=service-role-key
SUPABASE_JWT_SECRET=supabase-jwt-secret
SUPABASE_DB_URL=postgresql://db-user:db-password@db.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=case-files

# ───────────────────────────
# Air-Gapped / Self-Hosted
# ───────────────────────────
SELF_HOSTED_APP_URL=https://lexora.local
SELF_HOSTED_API_URL=https://lexora.local/api

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lexora
DB_USER=lexora
DB_PASSWORD=change-me
DB_SSL=false

# Auth (Custom JWT)
AUTH_ISSUER=https://lexora.local/auth
AUTH_AUDIENCE=lexora-enterprise
AUTH_JWT_ALGO=HS256
AUTH_JWT_SIGNING_KEY=change-me
AUTH_JWT_PUBLIC_KEY=optional-public-key

# Storage (MinIO)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=case-files
MINIO_ROOT_USER=lexora
MINIO_ROOT_PASSWORD=change-me
MINIO_REGION=us-east-1

# ───────────────────────────
# Email Integration
# ───────────────────────────
EMAIL_ENCRYPTION_KEY=change-me-32-char-secret-key
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=https://app.lexora.com/api/email/oauth/gmail/callback
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_REDIRECT_URI=https://app.lexora.com/api/email/oauth/outlook/callback

# ───────────────────────────
# Stripe Billing Integration
# ───────────────────────────
STRIPE_SECRET_KEY=sk_test_your-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (from Stripe Dashboard)
STRIPE_PRICE_ESSENTIAL=price_essential_monthly_id
STRIPE_PRICE_PROFESSIONAL=price_professional_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id

# ───────────────────────────
# Optional
# ───────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
